{
  "name": "@a2ui/vue",
  "version": "0.9.0-alpha.0",
  "description": "Vue renderer for A2UI (Agent-to-User Interface)",
  "homepage": "https://a2ui.org/",
  "repository": {
    "directory": "renderers/vue",
    "type": "git",
    "url": "git+https://github.com/google/A2UI.git"
  },
  "bugs": {
    "url": "https://github.com/google/A2UI/issues"
  },
  "keywords": [
    "a2ui",
    "vue",
    "ai",
    "agent",
    "ui",
    "renderer"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./v0_9": {
      "import": {
        "types": "./dist/v0_9/index.d.ts",
        "default": "./dist/v0_9/index.js"
      },
      "require": {
        "types": "./dist/v0_9/index.d.cts",
        "default": "./dist/v0_9/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "vue-tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@a2ui/web_core": "^0.9.0",
    "markdown-it": "^14.0.0"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.8.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.2.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0"
}
